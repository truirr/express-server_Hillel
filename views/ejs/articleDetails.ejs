<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <h1>Деталі статті</h1>

    <% if (article) { %>
      <div class="card">
        <h2><%= article.title %></h2>
        <p>ID: <%= article.id %></p>
        <p><%= article.description %></p>
      </div>
    <% } else { %>
      <div class="card">
        <h2>Статтю не знайдено</h2>
        <p>ID: <%= articleId %></p>
      </div>
    <% } %>

    <a class="back-link" href="/articles">Назад до статей</a>
  </div>
</body>
</html>
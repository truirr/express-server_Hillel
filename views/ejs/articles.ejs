<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <h1>Список статей</h1>

    <ul class="card-list">
      <% articles.forEach((article) => { %>
        <li class="card">
          <h2><%= article.title %></h2>
          <p><%= article.description %></p>
          <a href="/articles/<%= article.id %>">Детальніше</a>
        </li>
      <% }) %>
    </ul>
  </div>
</body>
</html>